{
  "name": "companion-memory-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --keep-vars",
    "setup:cloudflare": "node scripts/setup-cloudflare.mjs",
    "memory:fact-key-audit": "node scripts/fact-key-audit.mjs",
    "memory:relations-audit": "node scripts/memory-relations-audit.mjs",
    "memory:lmc5-coordinates": "node scripts/lmc5-coordinate-audit.mjs",
    "test:lmc5-circuits": "node scripts/lmc5-circuit-audit.mjs",
    "test:legacy-relations": "node scripts/run-legacy-relations-audit.mjs",
    "test:recall-regression": "node scripts/recall-regression.mjs",
    "deploy:cloudflare": "npm run setup:cloudflare && wrangler deploy --keep-vars",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply companion_memory_proxy --local",
    "db:migrate:remote": "wrangler d1 migrations apply companion_memory_proxy --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250927.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.40.2"
  }
}
